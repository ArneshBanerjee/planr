# ── AI provider ──────────────────────────────────────────────────────────────
# You normally don't need this file for the AI setup: pick a provider and paste
# your API key in the app itself (⚙️ Settings, top right). Choices:
#   ChatGPT (OpenAI) · Gemini (Google) · Claude API (Anthropic) · Claude Code (CLI, no key)
#
# Env vars below work as fallbacks for keys not saved in the app:
# LLM_PROVIDER=            # openai | gemini | anthropic | claude-code
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_PATH=        # path to the claude binary if it's not on PATH

# ── Google Calendar sync (optional) ──────────────────────────────────────────
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# and enable the Calendar API. Redirect URI: http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Your IANA timezone (defaults to Asia/Kolkata if unset)
PLANR_TIMEZONE=Asia/Kolkata
